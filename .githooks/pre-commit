#!/bin/sh

# Find the nearest pubspec.yaml for a file path and print the package name
resolve_package() {
  dir=$(dirname "$1")
  while [ "$dir" != "." ]; do
    if [ -f "$dir/pubspec.yaml" ]; then
      grep '^name:' "$dir/pubspec.yaml" | head -1 | sed 's/name: *//'
      return
    fi
    dir=$(dirname "$dir")
  done
}

# Resolve each staged file under packages/ to its package name
STAGED_FILES=$(git diff --cached --name-only | grep '^packages/')

if [ -z "$STAGED_FILES" ]; then
  echo "No package changes staged, skipping pre-commit checks."
  exit 0
fi

NAMES=""
for file in $STAGED_FILES; do
  name=$(resolve_package "$file")
  if [ -n "$name" ]; then
    NAMES="$NAMES $name"
  fi
done
NAMES=$(echo "$NAMES" | tr ' ' '\n' | sort -u | tr '\n' ' ' | sed 's/^ *//;s/ *$//')

if [ -z "$NAMES" ]; then
  echo "No packages found in staged changes, skipping pre-commit checks."
  exit 0
fi

SCOPE=""
for name in $NAMES; do
  SCOPE="$SCOPE --scope=$name"
done

# Auto-format staged .dart files and re-stage them
STAGED_DART=$(git diff --cached --name-only --diff-filter=d -- '*.dart')
if [ -n "$STAGED_DART" ]; then
  echo "Formatting staged .dart files..."
  dart format $STAGED_DART
  git add $STAGED_DART
fi

echo "Running pre-commit checks for:$NAMES"

melos exec $SCOPE --fail-fast --no-flutter --dir-exists=lib -- dart analyze --fatal-warnings &&
melos exec $SCOPE --fail-fast --flutter --dir-exists=lib -- flutter analyze --fatal-warnings
